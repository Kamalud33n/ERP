# ─── DATABASE ──────────────────────────────────────────
# SQLite (Local Development)
# DATABASE_URL=sqlite:///./erp.db
# PostgreSQL (Production Recommended)
# DATABASE_URL=postgresql://postgres:postgres_password@localhost:5432/mednova_erp
# MySQL (Active)
DATABASE_URL=mysql+pymysql://root:2002@localhost:3306/erp_db

# ─── AUTHENTICATION ────────────────────────────────────────
SECRET_KEY=mednova-erp-secret-key-2024-production-change-this-min32chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── EMAIL (SMTP) ──────────────────────────────────────────
# Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=noreply@mednova.com
SMTP_FROM_NAME=MedNova ERP

# Or SendGrid
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=SG.your-sendgrid-api-key

# Or Microsoft Graph
# GRAPH_CLIENT_ID=your-azure-client-id
# GRAPH_CLIENT_SECRET=your-azure-client-secret
# GRAPH_TENANT_ID=your-azure-tenant-id

# ─── CELERY & REDIS ────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TIMEZONE=UTC

# ─── FILE STORAGE (S3 or MinIO) ────────────────────────────
# MinIO (Local S3-compatible)
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_USE_SSL=False
MINIO_BUCKET_NAME=mednova-documents

# Or AWS S3
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# AWS_REGION=us-east-1
# AWS_S3_BUCKET_NAME=mednova-erp-docs

# ─── MFA & SECURITY ────────────────────────────────────────
MFA_ENABLED=True
MFA_ISSUER=MedNova ERP
REQUIRE_MFA_FOR_ROLES=admin,finance

# ─── LOGGING ────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=/var/log/mednova/app.log

# ─── API CONFIGURATION ─────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
ENV=production
API_DEBUG=False
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ─── INTEGRATIONS ──────────────────────────────────────────
# Biometric Device (ZKTeco)
BIOMETRIC_DEVICE_IP=192.168.1.100
BIOMETRIC_DEVICE_PORT=5200

# Government Systems
GOV_API_BASE_URL=https://api.gov.example.com
GOV_API_KEY=your-gov-api-key
GOV_API_SECRET=your-gov-api-secret

# Power BI
POWERBI_TENANT_ID=your-tenant-id
POWERBI_CLIENT_ID=your-client-id
POWERBI_CLIENT_SECRET=your-client-secret

# ─── BACKUP & MAINTENANCE ──────────────────────────────────
BACKUP_ENABLED=True
BACKUP_DAILY_TIME=02:00
BACKUP_RETENTION_DAYS=30
BACKUP_DESTINATION=s3://mednova-backups

# ─── FEATURES ──────────────────────────────────────────────
FEATURE_EMAIL_NOTIFICATIONS=True
FEATURE_SMS_NOTIFICATIONS=False
FEATURE_DOCUMENT_ARCHIVING=True
FEATURE_AUDIT_LOGGING=True
FEATURE_WORKFLOW_AUTOMATION=True